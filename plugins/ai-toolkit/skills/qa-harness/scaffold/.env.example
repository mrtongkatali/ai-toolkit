# qa-harness config. Copy to .env and fill in. .env is gitignored - never commit real creds.

# --- shared defaults (override only if you need to) ---
ENVIRONMENT=dev            # dev | staging  (selects the Playwright project / base URL)
CLIENT_ID=33517            # tenant id; tenant URL = <baseURL>/admin/<CLIENT_ID>

# --- machine-specific (set yours) ---
IMPACT_WEB_PATH=           # absolute path to your local Impact Web clone (analysis / grounding only)

# --- secrets (never commit) ---
QA_USER=                   # live-env login username
QA_PASS=                   # live-env login password

# --- optional ---
# PW_RETRIES=0             # Playwright flake retries; keep low
